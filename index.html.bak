                    oLi.innerHTML = "<a href=\"https://www.baidu.com/s?wd="+ value + "\">"+ value + "</a>";
                }

                if (p.includes('bing')) {
                    oLi.innerHTML = "<a href=\"https://cn.bing.com/search?q="+ value + "\">"+ value + "</a>";
                }
                if (p.includes('bilibili')) {
                    oLi.innerHTML = "<a href=\"https://search.bilibili.com/all?keyword="+ value + "\">"+ value + "</a>";
                }
                if (p.includes('metaso')) {
                    oLi.innerHTML = "<a href=\"https://metaso.cn/?s=alolk&referrer_s=alolk&q="+ value + "\">"+ value + "</a>";
                }
                 oUl.appendChild(oLi);
                })
                oUl.style.display = "block";
            }

