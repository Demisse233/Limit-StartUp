// 关闭抽屉（取消 navcheck 勾选）
function closeMenuDrawer() {
  var cb = document.getElementById('navcheck');
  if (cb && cb.checked) cb.checked = false;
}

// 打开弹窗的通用逻辑：先关抽屉，再开 opacity_bg 与目标 modal
function openModal(id) {
  closeMenuDrawer();
  var bg = document.querySelector('.opacity_bg');
  var el = document.getElementById(id);
  if (!el) return;
  if (bg) {
    bg.style.display = 'block';
    void bg.offsetWidth;
    bg.classList.add('is-open');
  }
  void el.offsetWidth;
  el.classList.add('is-open');
}

function closeModal(id) {
  var el = document.getElementById(id);
  if (el) el.classList.remove('is-open');
  var bg = document.querySelector('.opacity_bg');
  if (bg) {
    bg.classList.remove('is-open');
    setTimeout(function () { bg.style.display = 'none'; }, 320);
  }
}
// 兼容 body onload 调用的 load() — 原项目存在此调用，保留为 no-op
function load() {}

// 点击遮罩关闭所有弹窗（Apple 风格 modal 行为）
document.addEventListener('DOMContentLoaded', function () {
  var bg = document.querySelector('.opacity_bg');
  if (!bg) return;
  bg.addEventListener('click', function () {
    var ids = ['about', 'settings_box', 'shengming_box', 'question_box'];
    ids.forEach(function (id) {
      var el = document.getElementById(id);
      if (el) el.classList.remove('is-open');
    });
    bg.classList.remove('is-open');
    setTimeout(function () { bg.style.display = 'none'; }, 320);
  });
});

</script>
