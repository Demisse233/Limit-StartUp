                <div style="text-align: left;font-size: 17px;margin: 0;">
                    <br>
                    <span class="Q_ui_box">Q</span>&nbsp;为什么自定义壁纸再刷新后未保存？<br>
                    <span class="A_ui_box">A</span>&nbsp;自定义壁纸功能使用了浏览器本地存储 localStorage，请不要上传大小超过 4MB 大小的图片，否则将会无法保存。<br><br>
                    <br>
                    <span class="Q_ui_box">Q</span>&nbsp;更换浏览器后更改的设置还在吗？<br>
                    <span class="A_ui_box">A</span>&nbsp;设置功能使用了浏览器本地存储 localStorage，仅存储在当前浏览器中，更换浏览器后需要重新设置。<br><br>
                </div>
                <img src="/src/end.png" width="100%" style="margin-top: 16px;border-radius: 8px;">
            </div>



</div>


    <script src="https://cdn.bootcss.com/jquery/1.12.4/jquery.min.js"></script>
		<script type="text/javascript">


// 自定义问候语
let savedText = localStorage.getItem('welcomeText');
        if (savedText) {
            document.getElementById('input-text').value = savedText;
            document.getElementById('display-text').innerText = savedText;
        }

        document.getElementById('change-btn').addEventListener('click', function() {
            var inputText = document.getElementById('input-text').value;
            document.getElementById('display-text').innerText = inputText;
            localStorage.setItem('welcomeText', inputText);
            location.reload();
        });

// 自定义壁纸
function uploadImage() {
            const fileInput = document.getElementById('imageFile');
            if (fileInput.files && fileInput.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.body.style.backgroundImage = `url(${e.target.result})`;
                    localStorage.setItem('backgroundImage', e.target.result);
                };
                reader.readAsDataURL(fileInput.files[0]);
            }
            location.reload();
        }

        function resetBackground() {
            document.body.style.backgroundImage = '';
            localStorage.removeItem('backgroundImage');
            localStorage.removeItem('bg');
            location.reload();
        }
// 欢迎语
        function Movein() {
            var el = document.getElementById("success_box");
            el.style.opacity = "1";
            el.style.transform = "translate(-50%, 0)";
        }
        function Moveout() {
            var el = document.getElementById("success_box");
            el.style.opacity = "0";
            el.style.transform = "translate(-50%, -160%)";
        }
    // 修改默认搜索引擎
    function setDefault() {
            const selector1 = document.getElementById('searchEngineSelector1');
            const selector2 = document.getElementById('searchEngineSelector2');
            const selectedValue = selector1.options[selector1.selectedIndex].value;

            for (let i = 0; i < selector2.options.length; i++) {
                if (selector2.options[i].value === selectedValue) {
                    selector2.selectedIndex = i;
                    break;
                }
            }

            localStorage.setItem('defaultSearchEngine', selectedValue);
        }
// 加载
        window.onload = function() {
            const backgroundImageUrl = localStorage.getItem('backgroundImage');
            const selector1 = document.getElementById('searchEngineSelector1');
            const selector2 = document.getElementById('searchEngineSelector2');
            const defaultSearchEngine = localStorage.getItem('defaultSearchEngine');



            if (backgroundImageUrl) {
                document.body.style.backgroundImage = `url(${backgroundImageUrl})`;
            }
            Movein();
            setTimeout("Moveout()",5000 );

            if (defaultSearchEngine) {
                for (let i = 0; i < selector1.options.length; i++) {
                    if (selector1.options[i].value === defaultSearchEngine) {
                        selector1.selectedIndex = i;
                        break;
                    }
                }
                for (let i = 0; i < selector2.options.length; i++) {
                    if (selector2.options[i].value === defaultSearchEngine) {
                        selector2.selectedIndex = i;
                        break;
                    }
                }
                if (typeof syncEngineChips === 'function') {
                  syncEngineChips(defaultSearchEngine);
                }
            }
        };


// 预设壁纸
        if(localStorage.bg) $('head').append("<style class='font-style'>" + localStorage.bg + "</style>");

        // 高亮当前选中的预设壁纸
        (function highlightSelectedBg() {
          try {
            var bg = localStorage.getItem('bg') || '';
            // bg 形如 body{background:url('src/3.JPG');...}
            var m = bg.match(/src\/([0-9]+)\./);
            if (m) {
              var id = 'bg' + m[1];
              var el = document.getElementById(id);
              if (el) el.classList.add('is-selected');
            }
          } catch (e) {}
        })();


// 时间
     var t = null;
    t = setTimeout(time, 10);
    function time() {
        clearTimeout(t);
        dt = new Date();
        var y = dt.getFullYear();
        var mt = dt.getMonth() + 1;
        var day = dt.getDate();
        var h = (dt.getHours() < 10) ? ("0" + dt.getHours()) : dt.getHours();
		var m = (dt.getMinutes() < 10) ? ("0" + dt.getMinutes()) : dt.getMinutes();
        document.querySelector(".showTime").innerHTML = y + "年" + mt + "月" + day + "日"+" " + h + ":" + m;
        t = setTimeout(time, 1000);
    }





    var h = document.getElementById(count_days);
			timeDifference(`2023/4/18 00:00:00`, ``, count_days);
			function a() {
				timeDifference(`2023/4/18 00:00:00`, ``, count_days);
			}
			setInterval(a, 1000);




			function timeDifference(endT, endName = `2022/10/26`, obj) {
				var startTime = new Date().getTime();
				var endTime = new Date(endT).getTime();
				var secondDif = parseInt((endTime - startTime) / 1000);
				if (secondDif < 0) {
					var secondDifference = -secondDif;
				} else {
					var secondDifference = secondDif;
				}
				var day = parseInt(secondDifference / 24 / 60 / 60);
				if (secondDif < 0) {
					obj.innerHTML = `Limit Startup 已上线 ${endName}<span style="color:#f03752">${day < 10 ? '0' + day : day}  </span>天`
					return false;
				} else {
					obj.innerHTML = `${endName}<br><span>${day < 10 ? '0' + day : day} 天 </span>`
					return true;
				}

			}











// 搜索框
const btn = document.querySelector('.search_btn');
const point = document.querySelector('select');
const texts = document.querySelector('#input_text');

const arr = ['wd', 'q', 'keyword','q'];

btn.onclick = function() {
    const p = point.value;
    const text = texts.value;
    let str = '';

    if (p.includes('baidu')) {
    str = '?' + arr[0] + '=' + text;
    }

    if (p.includes('bing')) {
    str = '?' + arr[1] + '=' + text;
    }

    if (p.includes('bilibili')) {
    str = '?' + arr[2] + '=' + text;
    }

    if (p.includes('metaso')) {
    str =  arr[3] + '=' + text;
    }

    console.log(p + str);
    window.location.href = p + str;


}
document.onkeyup = function(e) {
    if (e.keyCode == 13) {
        btn.click();
    }
}

